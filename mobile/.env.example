# Copy to `.env`. Optional — the app falls back to http://localhost:8080 when unset.
#
# On a real device `localhost` means the phone itself, so use the PC's LAN IP:
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.0.10:8080
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# 💬 유저 설명 칸의 "라인 등록기" 링크. 지금은 로컬 편집기(`npm run author`)를 가리키고,
# 기여 사이트가 생기면 이 값만 그쪽 주소로 바꾸면 됩니다. 위와 같은 이유로 실기기에서는 LAN IP를 쓰세요.
EXPO_PUBLIC_AUTHOR_URL=http://localhost:4599
