{
  "expo": {
    "name": "Chessko",
    "slug": "chessko",
    "scheme": "chessko",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.comtea04.chessko"
    },
    "android": {
      "package": "com.comtea04.chessko",
      "adaptiveIcon": {
        "backgroundColor": "#0E1935",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "체스판 스크린샷을 선택하기 위해 사진 보관함 접근 권한이 필요합니다.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "backgroundColor": "#0E1935"
        }
      ],
      "expo-status-bar"
    ],
    "extra": {
      "eas": {
        "projectId": "f0f9abf5-5c34-4a4d-aa8a-6f520e608d96"
      }
    },
    "owner": "comtea04",
    "updates": {
      "url": "https://u.expo.dev/f0f9abf5-5c34-4a4d-aa8a-6f520e608d96"
    }
  }
}
