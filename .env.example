# Root-level env for docker-compose. Copy to `.env` and fill in as needed.
#
# The Java service's own secrets (OPENAI_API_KEY, SUPABASE_URL, SUPABASE_SERVICE_KEY,
# STOCKFISH_POOL_SIZE, CHESSKO_CORS_ALLOWED_ORIGINS, ...) live in backend/.env, which
# compose loads via `env_file`. This file is only for compose-level values.

# Required only for the `tls` profile (Caddy auto-HTTPS). Point this hostname's DNS at the host.
CADDY_DOMAIN=api.example.com

# Which interface publishes the API port. Defaults to 127.0.0.1, which is what a public host
# wants — Caddy fronts it over the compose network and nothing else can reach 8080.
# During development, set this to 0.0.0.0 so Expo Go on a phone can hit the PC's LAN IP.
# BACKEND_BIND=0.0.0.0
